# =========================
# Local development config
# Copy file này thành: chatbot/.env
# =========================

# --- Supabase (bắt buộc nếu muốn search / lưu chat history) ---
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# Optional: service role key (chỉ dùng server-side; cẩn thận, không public)
SUPABASE_SERVICE_ROLE_KEY=

# Set true để chạy UI mà không cần Supabase (nhiều tính năng sẽ trả rỗng)
SUPABASE_DISABLED=false

# RPC names (tuỳ theo DB functions bạn đã tạo)
SUPABASE_VECTOR_RPC=match_vpop_tracks
SUPABASE_LYRICS_RPC=match_lyrics

# --- LLM (Gemini) ---
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=models/gemini-2.0-flash

# (Optional) nhiều key để xoay quota.
# Có thể để 1 dòng phân tách bằng dấu phẩy, hoặc multiline (mỗi key 1 dòng) sau dấu '='
GEMINI_API_KEYS=

# (Optional) model cho intent.py (google-genai dùng tên không có prefix models/)
GEMINI_INTENT_MODEL=gemini-2.0-flash

# --- Supabase Storage (Models) ---
SUPABASE_MODELS_BUCKET=ml_models
# Prefix là *folder* trong bucket (không phải danh sách file). Ví dụ: models
SUPABASE_MODELS_PREFIX=

# Cache folder local để lưu model sau khi download (mặc định: .model_cache ở repo root)
MODEL_CACHE_DIR=

# Nếu bật, app ưu tiên dùng Storage/cache thay vì local (DA/models)
MODELS_PREFER_STORAGE=false
# Override cưỡng bức dùng Storage nếu có credentials: 1/0
MODELS_FORCE_STORAGE=

# --- Spotify (tuỳ chọn: dùng để lấy preview_url thật từ Spotify API) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
